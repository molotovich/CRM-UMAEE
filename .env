# Configuración del servidor Flask
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=dev-umaee-crm-key-12345

# Base de Datos (Si no se especifica, el sistema usará SQLite localmente)
# Para MySQL, usa: mysql+pymysql://user:pass@localhost:3306/crm_umaee
# Para SQL Server o PostgreSQL, descomentar y ajustar:
# DATABASE_URL=postgresql://user:pass@localhost:5432/crm_db
DATABASE_URL=sqlite:///backend/instance/crm.db

# Configuración de límites (Opcional)
UPLOAD_MAX_SIZE=10MB
